---
import resources from '../data/resources.json';
import site from '../data/site.json';
import EventBanner from './EventBanner.astro';
import ResourceSection from './ResourceSection.astro';
import SuppliesBoard from './SuppliesBoard.astro';
import { tt } from '../i18n.js';
const lang = 'es';
const classifiedsEnabled = import.meta.env.PUBLIC_CLASSIFIEDS_ENABLED === 'true';
---
<nav class="quick" aria-label="Acciones rápidas">
  <div class="wrap">
    <a class="qa qa-find" href="#personas">🔎 Buscar personas</a>
    <a class="qa qa-give" href="#donaciones">❤️ Donar</a>
    {classifiedsEnabled && <a class="qa qa-board" href="/clasificados/">📣 Clasificados</a>}
    <a class="qa qa-mind" href="#psicologico">🧠 Apoyo</a>
  </div>
</nav>
<EventBanner />

{classifiedsEnabled && (
  <div class="wrap cl-teaser">
    <a class="cl-cta" href="/clasificados/">📣 Clasificados — pedidos y ofertas de la comunidad →</a>
  </div>
)}

<section class="section" aria-labelledby="recursos-h">
  <div class="wrap">
    <h2 id="recursos-h">{tt(site.ui.resourcesHeading, lang)}</h2>
    <p class="lead">{tt(resources.meta.note_es ? { es: resources.meta.note_es } : site.tagline, lang)}</p>
    {resources.categories.map((cat) => <ResourceSection cat={cat} />)}
  </div>
</section>

<SuppliesBoard />
