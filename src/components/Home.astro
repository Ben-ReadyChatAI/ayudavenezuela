---
import resources from '../data/resources.json';
import site from '../data/site.json';
import EventBanner from './EventBanner.astro';
import ResourceSection from './ResourceSection.astro';
import SuppliesBoard from './SuppliesBoard.astro';
import { tt } from '../i18n.js';
const lang = 'es';
const classifiedsEnabled = import.meta.env.PUBLIC_CLASSIFIEDS_ENABLED === 'true';
const suggestionsEnabled = import.meta.env.PUBLIC_SUGGESTIONS_ENABLED !== 'false';

// Quick-nav is generated from the resource categories so it never drifts out of
// sync. Short labels keep the chips compact; accent classes highlight key ones.
// 'oficial' is intentionally excluded: official/government channels are widely
// distrusted in Venezuela, and leading with them would make the site read as
// pro-government ("chavista"). The section stays in the body, just not up front.
const quickHidden = new Set(['oficial']);
const quickLabels = {
  personas: 'Buscar personas',
  mascotas: 'Mascotas',
  hospitales: 'Hospitales',
  seguridad: 'Seguridad',
  donaciones: 'Donar',
  psicologico: 'Apoyo',
};
const quickAccent = { donaciones: 'qa-give' };
---
<nav class="quick" aria-label="Acciones rápidas">
  <div class="wrap">
    {resources.categories.filter((cat) => !quickHidden.has(cat.id)).map((cat) => (
      <a class:list={['qa', quickAccent[cat.id]]} href={`#${cat.id}`}>
        {cat.emoji} {quickLabels[cat.id] ?? tt(cat.title, lang)}
      </a>
    ))}
    {suggestionsEnabled && <a class="qa qa-board" href="/sugerir/">🔗 Sugerir enlace</a>}
    {classifiedsEnabled && <a class="qa qa-board" href="/clasificados/">📣 Clasificados</a>}
  </div>
</nav>
<EventBanner />

{suggestionsEnabled && (
  <div class="wrap cl-teaser">
    <a class="cl-cta" href="/sugerir/">Sugerir enlaces, canales de WhatsApp o correcciones</a>
  </div>
)}

<section class="section" aria-labelledby="recursos-h">
  <div class="wrap">
    <h2 id="recursos-h">{tt(site.ui.resourcesHeading, lang)}</h2>
    <p class="lead">{tt(resources.meta.note_es ? { es: resources.meta.note_es } : site.tagline, lang)}</p>
    {resources.categories.map((cat) => <ResourceSection cat={cat} />)}
  </div>
</section>

<SuppliesBoard />
