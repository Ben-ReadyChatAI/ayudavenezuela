---
import '../styles/global.css';
import site from '../data/site.json';
import { tt } from '../i18n.js';

const lang = 'es';
const { title, description } = Astro.props;
const pageTitle = title ?? `${tt(site.brand, lang)} — ${tt(site.tagline, lang)}`;
const pageDesc = description ?? tt(site.tagline, lang);
const canonical = site.site ?? `https://${site.domain}/`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#0e3a5b" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" />
    <meta name="color-scheme" content="light" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_VE" />
    <meta property="og:site_name" content={tt(site.brand, lang)} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <a class="skip" href="#contenido">{tt(site.ui.skipToContent, lang)}</a>

    <header class="site-header">
      <span class="sun" aria-hidden="true"></span>
      <div class="wrap">
        <p class="brand">Ayuda <span class="ve">Venezuela</span></p>
        <svg class="stars" viewBox="0 0 224 28" fill="#d6452f" role="img" aria-label="Las ocho estrellas — símbolo de solidaridad">
          <symbol id="estrella" viewBox="0 0 24 24"><path d="M12 2l2.9 6.26 6.84.62-5.17 4.53 1.54 6.69L12 16.9 5.89 20.63l1.54-6.69L2.26 9.4l6.84-.62z"/></symbol>
          <use href="#estrella" width="14" height="14" x="0" y="0" />
          <use href="#estrella" width="14" height="14" x="30" y="4.9" />
          <use href="#estrella" width="14" height="14" x="60" y="8.2" />
          <use href="#estrella" width="14" height="14" x="90" y="9.8" />
          <use href="#estrella" width="14" height="14" x="120" y="9.8" />
          <use href="#estrella" width="14" height="14" x="150" y="8.2" />
          <use href="#estrella" width="14" height="14" x="180" y="4.9" />
          <use href="#estrella" width="14" height="14" x="210" y="0" />
        </svg>
        <p class="tagline">{tt(site.tagline, lang)}</p>
      </div>
      <svg class="avila" viewBox="0 0 1440 140" role="img" aria-label="El Ávila sobre Caracas">
        <path fill="#a9c0b6" d="M0,80 C240,55 480,95 720,68 S1200,52 1440,78 L1440,140 L0,140 Z"/>
        <path fill="#6e9388" d="M0,96 C220,66 460,110 700,80 S1180,60 1440,92 L1440,140 L0,140 Z"/>
        <path fill="#2f5249" d="M0,114 C200,84 420,124 640,92 S1060,70 1280,106 S1400,98 1440,104 L1440,140 L0,140 Z"/>
      </svg>
    </header>

    <main id="contenido">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <p class="disclaimer">{tt(site.disclaimer, lang)}</p>
        {site.footer.submitUrl && (
          <p class="submit">
            <a href={site.footer.submitUrl} target="_blank" rel="noopener noreferrer">✏️ {tt(site.footer.submit, lang)}</a>
          </p>
        )}
        <p class="credit">{tt(site.footer.credit, lang)}</p>
        <p class="updated">Última actualización: {site.updated}</p>
        <a class="backtop" href="#contenido">↑ {tt(site.ui.backToTop, lang)}</a>
      </div>
    </footer>
  </body>
</html>
