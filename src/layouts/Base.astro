---
import '../styles/global.css';
import site from '../data/site.json';
import { tt } from '../i18n.js';

const lang = 'es';
const { title, description } = Astro.props;
const pageTitle = title ?? `${tt(site.brand, lang)} — ${tt(site.tagline, lang)}`;
const pageDesc = description ?? tt(site.tagline, lang);
const canonical = site.site ?? `https://${site.domain}/`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#0a37a0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" />
    <meta name="color-scheme" content="light" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_VE" />
    <meta property="og:site_name" content={tt(site.brand, lang)} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <a class="skip" href="#contenido">{tt(site.ui.skipToContent, lang)}</a>

    <header class="site-header">
      <span class="sun" aria-hidden="true"></span>
      <div class="wrap header-row">
        <a class="brand-lockup" href="/">
          <img class="logo" src="/logo.png?v=2" width="44" height="44" alt="" />
          <span class="brand">Ayuda <span class="ve">Venezuela</span></span>
        </a>
        <p class="tagline">{tt(site.tagline, lang)}</p>
      </div>
      <svg class="avila" viewBox="0 0 1440 140" preserveAspectRatio="xMidYMax slice" role="img" aria-label="El Ávila sobre Caracas">
        <path fill="#bcccf0" d="M0,80 C240,55 480,95 720,68 S1200,52 1440,78 L1440,140 L0,140 Z"/>
        <path fill="#7a96d6" d="M0,96 C220,66 460,110 700,80 S1180,60 1440,92 L1440,140 L0,140 Z"/>
        <path fill="#0a37a0" d="M0,114 C200,84 420,124 640,92 S1060,70 1280,106 S1400,98 1440,104 L1440,140 L0,140 Z"/>
      </svg>
    </header>

    <main id="contenido">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <p class="disclaimer">{tt(site.disclaimer, lang)}</p>
        {site.footer.submitUrl && (
          <p class="submit">
            <a href={site.footer.submitUrl} target="_blank" rel="noopener noreferrer">✏️ {tt(site.footer.submit, lang)}</a>
          </p>
        )}
        {site.footer.contactEmail && (
          <p class="contact">
            📧 {tt(site.footer.contact, lang)} <a href={`mailto:${site.footer.contactEmail}`}>{site.footer.contactEmail}</a>
          </p>
        )}
        <p class="credit">{tt(site.footer.credit, lang)}</p>
        <p class="updated">Última actualización: {site.updated}</p>
        <a class="backtop" href="#contenido">↑ {tt(site.ui.backToTop, lang)}</a>
      </div>
    </footer>
  </body>
</html>
