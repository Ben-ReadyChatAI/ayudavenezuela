---
import Base from '../layouts/Base.astro';

const enabled = import.meta.env.PUBLIC_CLASSIFIEDS_ENABLED === 'true';
const relayEnabled = import.meta.env.PUBLIC_RELAY_ENABLED === 'true';
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL || '';
const SUPABASE_ANON = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || '';
const configured = enabled && SUPABASE_URL && SUPABASE_ANON;

const estados = [
  'Amazonas','Anzoátegui','Apure','Aragua','Barinas','Bolívar','Carabobo','Cojedes',
  'Delta Amacuro','Distrito Capital','Falcón','Guárico','La Guaira','Lara','Mérida',
  'Miranda','Monagas','Nueva Esparta','Portuguesa','Sucre','Táchira','Trujillo','Yaracuy','Zulia'
];
const categorias = ['Refugio','Alimentos','Agua','Medicinas','Transporte','Voluntariado','Ropa','Rescate','Otro'];
---
<Base title="Clasificados — Ayuda Venezuela" description="Ofrece o pide ayuda y servicios de la comunidad tras el terremoto en Venezuela.">
  <section class="section">
    <div class="wrap">
      <h1>Clasificados — Ofrezco / Necesito</h1>

      {!enabled && <p class="lead">Esta sección estará disponible pronto.</p>}
      {enabled && !configured && <p class="lead">Sección en configuración. Vuelve más tarde.</p>}

      {configured && (
        <>
          <p class="lead">Publica un servicio que <strong>ofreces</strong> o que <strong>necesitas</strong>. La comunidad se ayuda entre sí.</p>
          <p class="caveat">⚠️ Tu publicación es pública. Desconfía de quien pida dinero por adelantado, criptomonedas o datos bancarios. No compartas información sensible.</p>

          <details class="cl-form-wrap">
            <summary class="cl-newbtn">+ Publicar un aviso</summary>
            <form id="cl-form" class="cl-form" novalidate>
              <div class="cl-row">
                <label>Tipo
                  <select name="tipo" required>
                    <option value="necesito">Necesito</option>
                    <option value="ofrezco">Ofrezco</option>
                  </select>
                </label>
                <label>Categoría
                  <select name="categoria" required>
                    {categorias.map((c) => <option value={c}>{c}</option>)}
                  </select>
                </label>
              </div>
              <label>Título *
                <input name="titulo" maxlength="120" required placeholder="Ej.: Ofrezco transporte de Caracas a La Guaira" />
              </label>
              <label>Descripción
                <textarea name="descripcion" maxlength="1000" rows="3" placeholder="Detalles útiles"></textarea>
              </label>
              <div class="cl-row">
                <label>Estado
                  <select name="estado">
                    <option value="">—</option>
                    {estados.map((e) => <option value={e}>{e}</option>)}
                  </select>
                </label>
                <label>Ciudad / zona
                  <input name="ciudad" maxlength="80" placeholder="Ej.: Caraballeda" />
                </label>
              </div>

              <fieldset class="cl-ct">
                <legend>¿Cómo te contactan? *</legend>
                <label class="cl-radio"><input type="radio" name="contacto_tipo" value="whatsapp" checked /> WhatsApp</label>
                {relayEnabled && <label class="cl-radio"><input type="radio" name="contacto_tipo" value="email" /> Email (privado)</label>}
              </fieldset>

              <label data-field="whatsapp">WhatsApp (con código de país) *
                <input name="whatsapp" maxlength="25" inputmode="tel" placeholder="+58 414 1234567" />
              </label>
              {relayEnabled && (
                <label data-field="email" hidden>Tu email * <span class="cl-hint">(no se mostrará; recibes los mensajes por correo)</span>
                  <input name="email" type="email" maxlength="200" placeholder="tu@correo.com" />
                </label>
              )}

              <button type="submit" class="cl-submit">Publicar</button>
              <p id="cl-msg" class="cl-msg" role="status"></p>
            </form>
          </details>

          <div id="cl-list" class="cards" aria-live="polite"></div>
          <p id="cl-empty" class="lead" hidden>Aún no hay avisos. Sé el primero en publicar.</p>
        </>
      )}
    </div>
  </section>

  {configured && (
    <script define:vars={{ SUPABASE_URL, SUPABASE_ANON, RELAY: relayEnabled }}>
      const REST = SUPABASE_URL.replace(/\/$/, '') + '/rest/v1/clasificados';
      const FUNC = SUPABASE_URL.replace(/\/$/, '') + '/functions/v1/contactar';
      // explicit columns — never select=* (the private `email` column is not readable by anon)
      const COLS = 'id,created_at,tipo,categoria,titulo,descripcion,estado,ciudad,contacto_tipo,whatsapp,status';
      const headers = { apikey: SUPABASE_ANON, Authorization: 'Bearer ' + SUPABASE_ANON };
      const listEl = document.getElementById('cl-list');
      const emptyEl = document.getElementById('cl-empty');
      const form = document.getElementById('cl-form');
      const msg = document.getElementById('cl-msg');

      // toggle contact field based on selected type
      const waField = form.querySelector('[data-field="whatsapp"]');
      const emailField = form.querySelector('[data-field="email"]');
      form.querySelectorAll('input[name="contacto_tipo"]').forEach((r) =>
        r.addEventListener('change', () => {
          const t = form.querySelector('input[name="contacto_tipo"]:checked').value;
          if (waField) waField.hidden = t !== 'whatsapp';
          if (emailField) emailField.hidden = t !== 'email';
        }));

      const fmtDate = (s) => { try { return new Date(s).toLocaleDateString('es-VE', { day: 'numeric', month: 'short' }); } catch { return ''; } };

      function waLink(row) {
        const num = (row.whatsapp || '').replace(/\D/g, '');
        if (!num) return null;
        const a = document.createElement('a');
        a.className = 'cl-wa';
        a.href = 'https://wa.me/' + num + '?text=' + encodeURIComponent('Hola, vi tu aviso en Ayuda Venezuela: ' + (row.titulo || ''));
        a.target = '_blank'; a.rel = 'noopener noreferrer';
        a.textContent = '💬 Contactar por WhatsApp';
        return a;
      }

      function emailContact(row) {
        const wrap = document.createElement('div');
        const btn = document.createElement('button');
        btn.type = 'button'; btn.className = 'cl-contactbtn'; btn.textContent = '✉️ Contactar';
        const box = document.createElement('div'); box.className = 'cl-replybox'; box.hidden = true;
        const ta = document.createElement('textarea'); ta.placeholder = 'Tu mensaje'; ta.maxLength = 2000; ta.rows = 3;
        const who = document.createElement('input'); who.placeholder = 'Tu contacto (teléfono o email)'; who.maxLength = 200;
        const send = document.createElement('button'); send.type = 'button'; send.className = 'cl-submit'; send.textContent = 'Enviar';
        const st = document.createElement('p'); st.className = 'cl-msg';
        box.append(ta, who, send, st);
        btn.addEventListener('click', () => { box.hidden = !box.hidden; });
        send.addEventListener('click', async () => {
          const mensaje = ta.value.trim();
          if (mensaje.length < 2) { st.textContent = 'Escribe un mensaje.'; return; }
          st.textContent = 'Enviando…'; send.disabled = true;
          try {
            const r = await fetch(FUNC, {
              method: 'POST',
              headers: { apikey: SUPABASE_ANON, 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: row.id, mensaje, remitente: who.value.trim() }),
            });
            if (!r.ok) throw new Error('HTTP ' + r.status);
            st.textContent = '¡Mensaje enviado!'; ta.value = ''; who.value = '';
          } catch (e) { st.textContent = 'No se pudo enviar. Intenta más tarde.'; }
          send.disabled = false;
        });
        wrap.append(btn, box);
        return wrap;
      }

      function card(row) {
        const el = document.createElement('div');
        el.className = 'card cl-card';
        const tag = document.createElement('span');
        tag.className = 'cl-tag ' + (row.tipo === 'ofrezco' ? 'ofrezco' : 'necesito');
        tag.textContent = row.tipo === 'ofrezco' ? 'Ofrezco' : 'Necesito';
        const cat = document.createElement('span'); cat.className = 'cl-cat'; cat.textContent = row.categoria || '';
        const top = document.createElement('div'); top.className = 'cl-top'; top.append(tag, cat);
        const h = document.createElement('div'); h.className = 'name'; h.textContent = row.titulo || '';
        el.append(top, h);
        if (row.descripcion) { const d = document.createElement('p'); d.className = 'cnote'; d.textContent = row.descripcion; el.append(d); }
        const loc = [row.ciudad, row.estado].filter(Boolean).join(', ');
        if (loc) { const l = document.createElement('span'); l.className = 'host'; l.textContent = '📍 ' + loc; el.append(l); }
        if (row.contacto_tipo === 'whatsapp') { const w = waLink(row); if (w) el.append(w); }
        else if (row.contacto_tipo === 'email' && RELAY) { el.append(emailContact(row)); }
        const dt = document.createElement('span'); dt.className = 'cl-date'; dt.textContent = fmtDate(row.created_at); el.append(dt);
        return el;
      }

      async function load() {
        try {
          const r = await fetch(REST + '?select=' + COLS + '&status=eq.publicado&order=created_at.desc&limit=100', { headers });
          if (!r.ok) throw new Error('HTTP ' + r.status);
          const rows = await r.json();
          listEl.innerHTML = '';
          if (!rows.length) { emptyEl.hidden = false; return; }
          emptyEl.hidden = true;
          rows.forEach((row) => listEl.append(card(row)));
        } catch (e) { listEl.innerHTML = ''; emptyEl.hidden = false; emptyEl.textContent = 'No se pudieron cargar los avisos.'; }
      }

      form.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const fd = new FormData(form);
        const tipoContacto = fd.get('contacto_tipo') || 'whatsapp';
        const payload = {
          tipo: fd.get('tipo'), categoria: fd.get('categoria'),
          titulo: (fd.get('titulo') || '').toString().trim(),
          descripcion: (fd.get('descripcion') || '').toString().trim() || null,
          estado: fd.get('estado') || null,
          ciudad: (fd.get('ciudad') || '').toString().trim() || null,
          contacto_tipo: tipoContacto,
          whatsapp: tipoContacto === 'whatsapp' ? (fd.get('whatsapp') || '').toString().trim() : null,
          email: tipoContacto === 'email' ? (fd.get('email') || '').toString().trim() : null,
          status: 'publicado',
        };
        if (payload.titulo.length < 3) { msg.textContent = 'Escribe un título.'; return; }
        if (payload.contacto_tipo === 'whatsapp' && (payload.whatsapp || '').replace(/\D/g, '').length < 7) { msg.textContent = 'Escribe un WhatsApp válido con código de país.'; return; }
        if (payload.contacto_tipo === 'email' && !/.+@.+\..+/.test(payload.email || '')) { msg.textContent = 'Escribe un email válido.'; return; }
        msg.textContent = 'Publicando…';
        try {
          const r = await fetch(REST + '?select=' + COLS, { method: 'POST', headers: { ...headers, 'Content-Type': 'application/json', Prefer: 'return=representation' }, body: JSON.stringify(payload) });
          if (!r.ok) throw new Error('HTTP ' + r.status);
          const [row] = await r.json();
          msg.textContent = '¡Publicado! Gracias.';
          form.reset();
          if (waField) waField.hidden = false;
          if (emailField) emailField.hidden = true;
          emptyEl.hidden = true;
          if (row) listEl.prepend(card(row));
        } catch (e) { msg.textContent = 'No se pudo publicar. Inténtalo de nuevo.'; }
      });

      load();
    </script>
  )}
</Base>
