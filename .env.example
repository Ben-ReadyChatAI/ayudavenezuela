# Ayuda Venezuela — environment example (link suggestions + admin review)
# Copy to .env and fill with real values. NEVER commit the real .env.
#
# The static frontend uses ONLY the publishable (anon) key, which must be
# exposed to the client via the PUBLIC_ prefix (Astro convention).
PUBLIC_SUPABASE_URL="https://deomqpstbqcjtfxrnwif.supabase.co"
PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"
PUBLIC_SUGGESTIONS_ENABLED="true"
PUBLIC_CLASSIFIEDS_ENABLED="false"

# The Supabase SECRET (service-role) key must NOT live in this repo or the
# frontend bundle. Use it only inside a server / Supabase edge function.
# SUPABASE_SECRET_KEY="set this only in a secure server environment"
